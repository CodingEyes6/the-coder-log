---
const today = new Date();
---

<footer class="w-full border-t border-slate-800/80 bg-slate-900/30 py-8 mt-auto text-center text-sm text-slate-500">
	<div class="max-w-4xl mx-auto px-6 flex flex-col items-center gap-4">
		
		<p class="font-medium">
			&copy; {today.getFullYear()} <span class="text-slate-400 font-semibold">The Coder Log</span>. All rights reserved.
		</p>

		<div class="flex justify-center gap-6 text-slate-400 font-medium">
			<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-blue-400 transition-colors duration-200 no-underline">GitHub</a>
			<a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="hover:text-blue-400 transition-colors duration-200 no-underline">Twitter</a>
		</div>

		<div class="w-12 h-[1px] bg-slate-800"></div>

		<div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs">
			<a href="/privacy" class="hover:text-blue-400 transition-colors duration-200 no-underline text-slate-500">Privacy Policy</a>
			<a href="/terms" class="hover:text-blue-400 transition-colors duration-200 no-underline text-slate-500">Terms of Service</a>
			<a href="/contact" class="hover:text-blue-400 transition-colors duration-200 no-underline text-slate-500">Contact Us</a>
		</div>

	</div>
</footer>