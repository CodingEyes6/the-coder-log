---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
// FIX 1: Astro ka optimized Image engine import kiya
import { Image } from 'astro:assets';

// Backend Logic: Database se posts fetch ho rahi hain
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-5xl mx-auto px-6 py-12 flex-1 w-full">
			<div class="mb-12 border-b border-slate-800 pb-8">
				<h1 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-3">
					The Engineering Log
				</h1>
				<p class="text-slate-400 text-base max-w-xl">
					Technical tutorials, deep dives into Android core internals, Flutter architecture patterns, and snippets from production apps.
				</p>
			</div>

			<section>
				<ul class="grid grid-cols-1 md:grid-cols-2 gap-8 p-0 m-0 list-none">
					{
						posts.map((post) => (
							<li class="group bg-slate-900/40 border border-slate-800 hover:border-blue-500/50 rounded-xl overflow-hidden shadow-sm transition-all duration-300 flex flex-col">
								{/* FIX 2: post.slug ko post.id se replace kiya */}
								<a href={`/blog/${post.id}/`} class="block overflow-hidden relative aspect-video bg-slate-950">
									{post.data.heroImage && (
										/* FIX 3: Native img ki jagah Astro ka <Image /> component laga diya */
										<Image 
											src={post.data.heroImage} 
											alt={post.data.title}
											class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 opacity-80 group-hover:opacity-100"
										/>
									)}
								</a>
								<div class="p-6 flex flex-col flex-1">
									<span class="text-xs font-semibold text-blue-400 uppercase tracking-wider mb-2 block">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<h2 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors duration-200 mb-3 leading-snug">
										<a href={`/blog/${post.id}/`} class="no-underline text-current">
											{post.data.title}
										</a>
									</h2>
									<p class="text-slate-400 text-sm line-clamp-2 mb-4 flex-1">
										{post.data.description || "Click to read this full technical log entry on Android and Flutter architecture."}
									</p>
									<a href={`/blog/${post.id}/`} class="text-sm font-semibold text-blue-400 group-hover:text-blue-300 flex items-center gap-1 no-underline">
										Read Article <span>&rarr;</span>
									</a>
								</div>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>