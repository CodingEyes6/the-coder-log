---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-4xl mx-auto px-6 py-20 flex flex-col items-center justify-center text-center flex-1">
	<span class="px-3 py-1 text-xs font-medium text-blue-400 bg-blue-950/40 border border-blue-800/60 rounded-full mb-6 tracking-wide animate-pulse">
		🚀 Learning in Public
	</span>

	<h1 class="text-5xl md:text-6xl font-black tracking-tight text-white mb-6 leading-tight">
		Building Apps, Writing Code, <br/>
		<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">
			Documenting the Journey.
		</span>
	</h1>

	<p class="text-lg md:text-xl text-slate-400 max-w-2xl mb-10 leading-relaxed">
		Hey, welcome to <span class="text-slate-200 font-semibold">The Coder Log</span>. This is my personal engineering space where I break down complex concepts in Android native development, Flutter architecture, and the daily chaos of writing clean code.
	</p>

	<div class="flex flex-col sm:flex-row gap-4 justify-center w-full sm:w-auto">
		<a href="/blog" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg shadow-lg shadow-blue-600/20 transition duration-200 text-center">
			Read My Log (Blog)
		</a>
		<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 font-semibold rounded-lg border border-slate-700 transition duration-200 text-center">
			Check My GitHub
		</a>
	</div>
</main>
		<Footer />
	</body>
</html>
